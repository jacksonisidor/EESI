# Copy to .env at the repository root and fill in values.
# cp .env.example .env
#
# Obtain EC2 host, SSH user, DB password, AWS profile, and bucket name
# from your GEN administrator — do not commit real credentials.

# --- PostgreSQL (reference database on EC2 or local) ---
# Local machine: use SSH tunnel (see README §4.2) and EESI_DB_HOST=localhost
# On EC2: EESI_DB_HOST=localhost (no tunnel)
EESI_DB_HOST=localhost
EESI_DB_PORT=5432
EESI_DB_NAME=eesi
EESI_DB_USER=eesi
EESI_DB_PASSWORD=your_password_here

# --- AWS S3 (match images) ---
# aws sso login --profile <aws-profile>
# export AWS_PROFILE=<aws-profile>
EESI_S3_BUCKET=your_bucket_name_here

# --- Local machine only: SSH tunnel before querying DB ---
# ssh -L 5432:localhost:5432 <username>@<ec2-host> -N
# Background: ssh -f -L 5432:localhost:5432 <username>@<ec2-host> -N

# --- Query embedding column (must match how reference DB was indexed) ---
# Recommended production value: base_clip_embedding
EESI_EMBEDDING_COLUMN=base_clip_embedding

# --- Electron / Python bridge (optional) ---
# Path to Python 3.11+ with pipeline dependencies installed
# PYTHON_EXECUTABLE=python3
# Repository root override (auto-detected if unset)
# EESI_ROOT=/path/to/EESI

# --- Dev server (optional; default 5173) ---
# VITE_DEV_SERVER_PORT=5173
# VITE_DEV_SERVER_URL=http://localhost:5173
